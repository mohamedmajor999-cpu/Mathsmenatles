{
  "title": "Calculs avec logarithmes de base 10, 5, 2",
  "dest": [
    "HPL"
  ],
  "consigne": "Simplifier",
  "options": [
    {
      "name": "Somme de logarithmes de base 10",
      "consts": {
        "duos": [
          [
            1,
            10
          ],
          [
            2,
            5
          ],
          [
            5,
            2
          ],
          [
            10,
            1
          ],
          [
            1,
            100
          ],
          [
            2,
            50
          ],
          [
            4,
