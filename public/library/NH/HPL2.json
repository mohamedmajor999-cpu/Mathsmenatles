          ],
          [
            10,
            10
          ],
          [
            20,
            5
          ],
          [
            25,
            4
          ],
          [
            50,
            2
          ],
          [
            100,
            1
          ],
          [
            1,
            1000
          ],
          [
            2,
            500
          ],
          [
            4,
            250
          ],
          [
            5,
            200
          ],
          [
            8,
            125
          ],
          [
            10,
            100
          ],
          [
            20,
            50
          ],
          [
            25,
