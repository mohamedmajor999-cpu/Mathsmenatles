{
    "title":"Puissances négatives et fractions",
    "type":"latex",
    "ID":"HP1",
    "description":"Donner une fraction correspondant à la puissance négative",
    "dest":["HPF"],
    "consts":{"lettres":["a","b","c","d","u","v","t","x","y","z"]},
    "consigne":"Donner une fraction égale à la puissance",
    "options":[{
        "name":"Inverse d'une variable",
        "vars":{"a":"0_9", "l":"${:lettres[:a]}"},
        "question": "${:l}^{-1}",
        "answer":":question=\\color{red}{\\dfrac{1}{${:l}}}",
        "value":"\\dfrac{1}{${:l}}"
    }, {
        "name":"Inverse d'une fraction en notation anglo-saxonne",
        "vars":{
            "a":"1_9",
            "b":"1_9",
            "c":"1_9",
            "not":"${:a}\\frac{${:b}}{${:c}}",
            "inv":"\\dfrac{${:c}}{${:a*:c+:b}}"
        },
        "question":"\\left(${:not}\\right)^{-1}",
        "answer":":question=\\color{red}{${:inv}}",
        "value":"${:inv}"
    }, {
        "name":"Puissance négative d'un entier positif",
        "vars":{"p":"-3_-2", "a":"2_${:p==-3?5:15}"},
        "question":"${:a}^{${:p}}",
        "answer":":question=\\color{red}{\\dfrac{1}{${:a**(-:p)}}}",
        "value":"\\dfrac{1}{${:a**(-:p)}}"
    }, {
        "name":"Puissance négative d'un entier négatif",
        "vars":{"p":"-3_-2", "a":"${:p==-3?-5:-15}_-2"},
        "question":"(${:a})^{${:p}}",
        "answer":":question=\\color{red}{\\dfrac{${:p==-3?-1:1}}{${(-:a)**(-:p)}}}",
        "value":["\\dfrac{${:p==-3?-1:1}}{${(-:a)**(-:p)}}", "\\dfrac1{:a**(-:p)}"]
    }, {
        "name":"Puissance négative d'une variable",
        "vars":{"p":"-10_-2", "l":"0_9", "a":"${:lettres[:l]}"},
        "question":"${:a}^{${:p}}",
        "answer":":question=\\color{red}{\\dfrac{1}{${:a}^{${-:p}}}}",
        "value":"\\dfrac{1}{${:a}^{-:p}}"
    }, {
        "name":"Puissance négative d'une fraction",
        "vars":{"p":"-3_-2", "a":"2_${:p==-3?5:15}", "b":"2_${:p==-3?5:15}"},
        "question":"\\left(\\dfrac{${:a}}{${:b}}\\right)^{${:p}}",
        "answer":":question=\\color{red}{\\dfrac{${:b**(-:p)}}{${:a**(-:p)}}}",
        "value":"\\dfrac{${:a}}{${:b}^{-:p}}"
    }, {
        "name":"Puissance négative d'une puissance négative de 10",
        "vars":{"d":"-6_-1", "p":"-6_-1"},
        "question":"${MMmath.round(10**:d,8)}^{${:p}}",
        "answer":":question=\\color{green}{10^{${:d}\\times(${:p})}}=\\color{red}{${10**(:d*:p)}}",
        "value":"${:d**(-:p)}"
    }
    ]
}