            "answer":"<table class='inline-table'><tr><th></th><th>${:c1}</th><th>${:c2}</th><th>Total</th></tr><tr><th>${:l1}</th><td>${:connu[0]?:v[0]:'$$\\color{green}{'+:v[0]+'}$$'}</td><td>${:connu[1]?:v[1]:'$$\\color{green}{'+:v[1]+'}$$'}</td><td>${:connu[2]?:tl1:'$$\\color{green}{'+:tl1+'}$$'}</td></tr><tr><th>${:l2}</th><td>${:connu[3]?:v[2]:'$$\\color{green}{'+:v[2]+'}$$'}</td><td>${:connu[4]?:v[3]:'$$\\color{green}{'+:v[3]+'}$$'}</td><td>${:connu[5]?:tl2:'$$\\color{green}{'+:tl2+'}$$'}</td></tr><tr><th>Total</th><td>${:connu[6]?:tc1:'$$\\color{green}{'+:tc1+'}$$'}</td><td>${:connu[7]?:tc2:'$$\\color{green}{'+:tc2+'}$$'}</td><td>${:connu[8]?:tl1+:tl2:'$$\\color{green}{'+(:tc1+:tc2)+'}$$'} </td></tr></table><br><b>1.</b> ${:reponses[:nq[0]]}<br><b>2.</b> ${:reponses[:nq[1]]}"
