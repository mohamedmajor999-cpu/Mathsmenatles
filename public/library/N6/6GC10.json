        "C":"${:lettres[:l[2]]}",
        "cBC":["${:B+:C}","${:C+:B}"],
        "ABC":["${:A+:B+:C}","${:B+:C+:A}","${:C+:A+:B}","${:A+:C+:B}","${:B+:A+:C}","${:C+:B+:A}"],
