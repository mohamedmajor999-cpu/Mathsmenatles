    "options":[
        {
            "name":"Tableau pour deux objets",
            "vars":{
                "id1":"0_${:icons.length-1}",
                "id2":"0_${:icons.length-1}_^${:id1}",
                "obj1url":"${:icons[:id1][2]}",
                "obj2url":"${:icons[:id2][2]}",
                "nbobj":"8_16",
                "suiteobjets":"0_1_${:nbobj}",
                "nbp1":"${:suiteobjets.filter(x=>x===1).length}",
                "nbp2":"${:nbobj-:nbp1}"
            },
            "question":"Crée un tableau pour résumer la liste <b>${:icons[:id1][0]}</b> et de <b>${:icons[:id2][1]}</b>.<br>${:suiteobjets.map(x=>'<custom-svg src=library/illustrations/iconify/icon-park-outline--'+(x?:obj1url::obj2url)+'></custom-svg>').join(' ')}",
            "answer":"<table class='inline-table'><tr><th>Objet</th><th>${:icons[:id1][1]}</td><th>${:icons[:id2][1]}</th></tr><tr><td>Quantité</td><td>$$\\color{red}{${:nbp1}}$$</td><td>$$\\color{red}{${:nbp2}}$$</td></tr></table>"
        },{
            "name":"Tableau de trois objets",
            "vars":{
                "id1":"0_${:icons.length-1}",
                "id2":"0_${:icons.length-1}_^${:id1}",
                "id3":"0_${:icons.length-1}_^${:id1},${:id2}",
                "obj1url":"${:icons[:id1][2]}",
                "obj2url":"${:icons[:id2][2]}",
                "obj3url":"${:icons[:id3][2]}",
                "nbobj":"10_20",
                "suiteobjets":"0_2_${:nbobj}",
                "nbp1":"${:suiteobjets.filter(x=>x===0).length}",
                "nbp2":"${:suiteobjets.filter(x=>x===1).length}",
                "nbp3":"${:nbobj-:nbp1-:nbp2}"
            },
            "question":"Crée un tableau pour résumer la liste <b>${:icons[:id1][0]}</b>, <b>${:icons[:id2][0]}</b> et <b>${:icons[:id3][0]}</b>.<br>${:suiteobjets.map(x=>'<custom-svg src=library/illustrations/iconify/icon-park-outline--'+(x==0?:obj1url:x==1?:obj2url::obj3url)+'></custom-svg>').join(' ')}",
            "answer":"<table class='inline-table'><tr><th>Objet}</th><th>${:icons[:id1][1]}</th><th>${:icons[:id2][1]}</th><th>${:icons[:id3][1]}</th></tr><tr><td>Quantité</td><td>$$\\color{red}{${:nbp1}}$$</td><td>$$\\color{red}{${:nbp2}}$$</td><td>$$\\color{red}{${:nbp3}}$$</td></tr></table>"
        },{
            "name":"Tableau de deux couleurs",
            "vars":{
                "idobj":"0_${:icons.length-1}",
                "objurl":"${:icons[:idobj][2]}",
                "idcolors":"0_${:colors.length-1}_2_^&",
                "couleur1":"${:colors[:idcolors[0]][0]}",
                "couleur2":"${:colors[:idcolors[1]][0]}",
                "color1":"${:colors[:idcolors[0]][1]}",
                "color2":"${:colors[:idcolors[1]][1]}",
                "nbobj":"8_16",
                "suiteobjets":"0_1_${:nbobj}",
                "nbp1":"${:suiteobjets.filter(x=>x===1).length}",
                "nbp2":"${:nbobj-:nbp1}"
            },
            "question":"Crée un tableau pour résumer la liste <b>${:icons[:idobj][0]}</b> dont les couleurs sont : ${:couleur1} et ${:couleur2}</b>.<br>${:suiteobjets.map(x=>'<custom-svg style=color:'+(x===1?:color1::color2)+' src=library/illustrations/iconify/icon-park-outline--'+:objurl+'></custom-svg>').join(' ')}",
            "answer":"<table class='inline-table'><tr><th>${:icons[:idobj][1]}</th><th>${:couleur1}</th><th>${:couleur2}</th></tr><tr><td>Quantité</td><td>$$\\color{red}{${:nbp1}}$$</td><td>$$\\color{red}{${:nbp2}}$$</td></tr></table>"
        },{
            "name":"Compléter un tableau de trois couleurs",
            "vars":{
                "idobj":"0_${:icons.length-1}",
                "objurl":"${:icons[:idobj][2]}",
                "idcolors":"0_${:colors.length-1}_3_^&",
                "couleur1":"${:colors[:idcolors[0]][0]}",
                "couleur2":"${:colors[:idcolors[1]][0]}",
                "couleur3":"${:colors[:idcolors[2]][0]}",
                "color1":"${:colors[:idcolors[0]][1]}",
                "color2":"${:colors[:idcolors[1]][1]}",
                "color3":"${:colors[:idcolors[2]][1]}",
                "nbobj":"10_20",
                "suiteobjets":"0_2_${:nbobj}",
                "nbp1":"${:suiteobjets.filter(x=>x===0).length}",
                "nbp2":"${:suiteobjets.filter(x=>x===1).length}",
                "nbp3":"${:nbobj-:nbp1-:nbp2}"
            },
            "question":"Crée un tableau pour résumer la liste <b>${:icons[:idobj][0]}</b> dont les couleurs sont : ${:couleur1}, ${:couleur2} et ${:couleur3}</b>.<br>${:suiteobjets.map(x=>'<custom-svg style=color:'+(x===0?:color1:x==1?:color2::color3)+' src=library/illustrations/iconify/icon-park-outline--'+:objurl+'></custom-svg>').join(' ')}",
            "answer":"<table class='inline-table'><tr><th>${:icons[:idobj][1]}</th><th>${:couleur1}</th><th>${:couleur2}</th><th>${:couleur3}</th></tr><tr><td>Quantité</td><td>$$\\color{red}{${:nbp1}}$$</td><td>$$\\color{red}{${:nbp2}}$$</td><td>$$\\color{red}{${:nbp3}}$$</td></tr></table>"
        }
    ]
}