        ["de papillons","papillons","butterfly.svg"],
        ["de carottes","carottes","carrot.svg"],
        ["de chateaux","chateaux","castle.svg"],
        ["de palmiers","palmiers","coconut-tree.svg"],
        ["de diamants","diamants","diamond.svg"],
        ["de ballons de basket","ballons de basket","dribble.svg"],
        ["de canards","canards","duck.svg"],
        ["d’éléphants","éléphants","elephant.svg"],
        ["de smileys","smileys","emotion-happy.svg"],
        ["de microphones","micros","entertainment.svg"],
        ["de fantomes","fantomes","ghost.svg"],
        ["de ceintres","ceintres","hanger.svg"],
