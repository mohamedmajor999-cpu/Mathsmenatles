{
    "title":"Calculer une expression ﾃ coefficients positifs",
    "type":"latex",
    "ID":"5NE10",
    "textSize":"medium",
    "dest":["5NE", "4NE", "3ND","2N3"],
    "consts":{"lettres":["u","v","t","x", "y", "z"]},
    "vars":{"l":"0_5","x":"${:lettres[:l]}"},
    "options":[{
        "name":"Forme a + bx, x positif",
        "vars":{"a":"1_10","b":"0_10", "v":"0_10","exp":"${MMmath.calc(:a+'*'+:x+'+('+:b+')')}", "ans":"${:a*:v+:b}"}
    },{
        "name":"Forme a + bxﾂｲ, x positif",
        "vars":{"a":"1_10","b":"0_10", "v":"0_3","exp":"${MMmath.calc(:a+'*'+:x+'^2+('+:b+')')}", "ans":"${:a*:v*:v+:b}"}
    },{
        "name":"Forme a + bx + cxﾂｲ, x positif",
        "vars":{"a":"1_10","b":"1_10", "c":"1_3", "v":"0_3","exp":"${MMmath.calc(:a+'*'+:x+'^2+('+:b+')*'+:x+'+('+:c+')')}", "ans":"${:a*:v*:v+:b*:v+:c}"}
    },{
        "name":"Forme a + bxﾂｳ, x positif",
        "vars":{"a":"1_10","b":"0_10", "v":"0_3","exp":"${MMmath.calc(:a+'*'+:x+'^3+('+:b+')')}", "ans":"${:a*:v*:v*:v+:b}"}
    },{
        "name":"Forme (x + a)ﾃ傭, x positif",
        "vars":{"a":"1_10","b":"1_10", "v":"0_5","exp":"(${MMmath.calc(:a+'+'+:x)})\\times${:b>0?:b:'('+:b+')'}", "ans":"${(:a+:v)*:b}"}
    },{
        "name":"Forme (a + bx)ﾃ幼, x positif",
        "vars":{"a":"1_10","b":"0_10","c":"0_10", "v":"0_4","exp":"(${MMmath.calc(:a+'*'+:x+'+('+:b+')')})\\times${:c>0?:c:'('+:c+')'}", "ans":"${(:a*:v+:b)*:c}"}
    },{
        "name":"Forme a + bx, x nﾃｩgatif",
        "vars":{"a":"1_10","b":"0_10", "v":"-5_-1","exp":"${MMmath.calc(:a+'*'+:x+'+('+:b+')')}", "ans":"${:a*:v+:b}"}
    },{
        "name":"Forme a + bxﾂｲ, x nﾃｩgatif",
        "vars":{"a":"1_10","b":"0_10", "v":"-3_-1","exp":"${MMmath.calc(:a+'*'+:x+'^2+('+:b+')')}", "ans":"${:a*:v*:v+:b}"}
    },{
        "name":"Forme a + bx + cxﾂｲ, x nﾃｩgatif",
        "vars":{"a":"1_10","b":"0_10", "c":"1_3", "v":"-3_-1","exp":"${MMmath.calc(:a+'*'+:x+'^2+('+:b+')*'+:x+'+('+:c+')')}", "ans":"${:a*:v*:v+:b*:v+:c}"}
    },{
        "name":"Forme a + bxﾂｳ, x nﾃｩgatif",
        "vars":{"a":"1_10","b":"0_10", "v":"-3_-1","exp":"${MMmath.calc(:a+'*'+:x+'^3+('+:b+')')}", "ans":"${:a*:v*:v*:v+:b}"}
    },{
        "name":"Forme (x + a)ﾃ傭, x nﾃｩgatif",
        "vars":{"a":"1_10","b":"0_10", "v":"-5_-1","exp":"(${MMmath.calc(:a+'+'+:x)})\\times${:b>0?:b:'('+:b+')'}", "ans":"${(:a+:v)*:b}"}
    },{
        "name":"Forme (a + bx)ﾃ幼, x nﾃｩgatif",
        "vars":{"a":"1_10","b":"0_10","c":"0_10", "v":"-4_-1","exp":"(${MMmath.calc(:a+'*'+:x+'+('+:b+')')})\\times${:c>0?:c:'('+:c+')'}", "ans":"${(:a*:v+:b)*:c}"}
    }
    ],
    "question":"\\begin{gathered} \\text{Calculer }${:exp} \\\\ \\text{ pour } ${:x}=${:v}\\end{gathered}",
    "shortq":"\\begin{gathered} ${:exp} \\\\ \\text{ pour } ${:x}=${:v}\\end{gathered}",
    "answer":"\\text{Pour }${:x}=${:v}\\quad ${:exp}=\\color{red}{${:ans}}",
    "value":"${:ans}"
}