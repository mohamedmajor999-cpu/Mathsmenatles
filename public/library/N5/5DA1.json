        "c":[["Quelle est la donnée la plus représentée ?", "La donnée la plus représentée est <span class='red'>${:b[:f][:a.indexOf(Math.max(...:a))]}</span>", "${Math.max(...:a)}"],
        ["Quelle est la donnée la moins représentée ?","La donnée la moins représentée est <span class='red'>${:b[:f][:a.indexOf(Math.min(...:a))]}</span>", "${Math.min(...:a)}"]],
        "m":[["${:a[0]}","${:a[1]}","${:a[2]}","${:a[3]}","${:a[4]}"],["${10*:a[0]}","${10*:a[1]}","${10*:a[2]}","${10*:a[3]}","${10*:a[4]}"]]
    },
    "options":[
        {"name":"barres",
            "vars":{
