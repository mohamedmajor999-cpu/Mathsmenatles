                "g":"0_1",
            "legend":false
            }
        },
        {"name":"barres horizonales",
        "vars":{
            "a":"10_100_5_^&",
            "n":0,
            "d": "horizontal",
            "ia":"y",
            "f":"0_2",
            "g":"0_1",
            "legend":false
            }
        },
        {"name":"Diagramme circulaire",
