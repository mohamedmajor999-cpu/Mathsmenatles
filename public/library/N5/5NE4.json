{
    "title":"Tester une égalité",
    "type":"latex",
    "ID":"5NE4",
    "description":"Tester des égalités de",
    "dest":["5NE","4NE","3ND","2N3"],
    "textSize":"medium",
    "keys":["V","F"],
    "consigne":"Vérifier l’égalité",
    "consts":{"lettres":["u","v","t","x", "y", "z"]},
    "options":[{
        "name":"ax + b = cx + d, paramètres positifs",
        "vars":{"l":"0_5","x":"${:lettres[:l]}","sol":"1_6","cx":"1_3","b":"1_5","e":"1_5","d":"${:e*:sol+:b}","c":"1_5", "a":"${MMmath.round((:d-:b+:c*:sol)/:sol,3)}", "na":"0_6_^${:sol}"},
        "question": "\\begin{array}{l}${MMmath.signIfOne(:a)}${:x}+${:b}=${MMmath.signIfOne(:c)}${:x}+${:d}\\\\ \\text{pour } ${:x}=${:cx<2?:na::sol}\\end{array}",
        "answer":":question \\begin{array}{l}\\color{red}{\\text{ ${:cx<2?'FAUX':'VRAI'}}}\\\\ \\color{blue}{${MMmath.signIfOne(:a)}\\times${:cx<2?:na::sol}+${:b}=\\bold{${:a*(:cx<2?:na::sol)+:b}} \\text{ ${:cx<2?'mais':'et'} }${MMmath.signIfOne(:c)}\\times${:cx<2?:na::sol}+${:d}=\\bold{${:c*(:cx<2?:na::sol)+:d}}}\\end{array}",
        "value":"${:cx<2?'FAUX':'VRAI'}"
    },{
        "name":"ax + b = cx + d, paramètres relatifs",
        "vars":{"l":"0_5","x":"${:lettres[:l]}","sol":"-6_6_^0","cx":"1_3","b":"-5_5_^0","e":"-5_5_^0","d":"${:e*:sol+:b}","c":"-5_5_^0", "a":"${MMmath.round((:d-:b+:c*:sol)/:sol,3)}", "na":"-6_6_^${:sol}"},
        "question": "\\begin{array}{l}${:a==0?'':MMmath.signIfOne(:a)+:x}${:a==0?:b:MMmath.signedNumber(:b)}=${MMmath.signIfOne(:c)}${:x}${MMmath.signedNumber(:d)}\\\\ \\text{pour } ${:x}=${:cx<2?:na::sol}\\end{array}",
        "answer":":question \\begin{array}{l}\\color{red}{\\text{ ${:cx<2?'FAUX':'VRAI'}}}\\\\ \\color{blue}{${:a==0?''::a+'\\times'+MMmath.nP(:cx<2?:na::sol)}${:a==0?:b:MMmath.signedNumber(:b)}=\\bold{${:a*(:cx<2?:na::sol)+:b}} \\text{ ${:cx<2?'mais':'et'} } ${:c}\\times${MMmath.nP(:cx<2?:na::sol)}${MMmath.signedNumber(:d)}=\\bold{${:c*(:cx<2?:na::sol)+:d}}}\\end{array}",
        "value":"${:cx<2?'FAUX':'VRAI'}"
    },{
        "name":"(x+a)b = cx+d, paramètres positifs",
        "vars":{"l":"0_5","x":"${:lettres[:l]}","sol":"1_6","cx":"1_5","a":"1_6_^${:sol}","c":"1_6","b":"2_6_^${:c}","d":"${(:b-:c)*:sol+:a*:b}","na":"0_6_^${:sol}"},
        "question":"\\begin{array}{l}(${:x}+${:a})\\times ${:b}=${MMmath.signIfOne(:c)}${:x}${MMmath.signedNumber(:d)} \\\\ \\text{pour } ${:x}=${:cx<3?:na::sol}\\end{array}",
        "answer":":question \\begin{array}{l}\\color{red}{\\text{ ${:cx<3?'FAUX':'VRAI'}}}\\\\ \\color{blue}{(${:cx<3?:na::sol}+${:a})\\times ${:b}=\\bold{${((:cx<3?:na::sol)+:a)*:b}} \\text{ ${:cx<2?'mais':'et'} } ${MMmath.signIfOne(:c)}\\times${:cx<3?:na::sol}${MMmath.signedNumber(:d)}=\\bold{${:c*(:cx<3?:na::sol)+:d}}}\\end{array}",
        "value":"${:cx<3?'FAUX':'VRAI'}"
    },{
        "name":"b(x+a) = cx+d, paramètres relatifs",
        "vars":{"l":"0_5","x":"${:lettres[:l]}","sol":"-6_6","cx":"1_5","a":"-6_6_^${:sol},0","c":"-6_6_^0","b":"-6_6_^-1,0,1,${:c}","d":"${(:b-:c)*:sol+:a*:b}","na":"0_6_^${:sol}"},
        "question":"\\begin{array}{l}${:b}(${:x}${MMmath.signedNumber(:a)})=${MMmath.signIfOne(:c)}${:x}${MMmath.signedNumber(:d)} \\\\ \\text{pour } ${:x}=${:cx<3?:na::sol}\\end{array}",
        "answer":":question \\begin{array}{l}\\color{red}{\\text{ ${:cx<3?'FAUX':'VRAI'}}} \\\\ \\color{blue}{${:b}\\times(${:cx<3?:na::sol}${MMmath.signedNumber(:a)})=\\bold{${:b*((:cx<3?:na::sol)+:a)}} \\text{ ${:cx<2?'mais':'et'} }${MMmath.signIfOne(:c)}\\times ${MMmath.nP(:cx<3?:na::sol)} ${MMmath.signedNumber(:d)}=\\bold{${:c*(:cx<3?:na::sol)+:d}}}\\end{array}",
        "value":"${:cx<3?'FAUX':'VRAI'}"
    }
    ]
}