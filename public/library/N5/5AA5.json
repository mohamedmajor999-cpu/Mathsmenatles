                    "poire","pomme","banane","a", "b", "c","chien","chat","truc","machin"
                ]
            },
            "vars":{"a":"1_10", "r":"1_9", "b":"-10_10_^0", "ope0":"0_2", "var0":"0_9", "var":"${:varnames[:var0]}", "varoupas":"0_1"},
            "figure": {
                "type":"scratch",
                "content":[
