                ]
            },
            "question":"Que va dire le lutin ?",
            "answer":"Le lutin va dire <span class='red'>${:varoupas==0?:var::valeurs[:ope0]}</span>.",
            "value":"${:varoupas==0?:var::valeurs[:ope0]}"
        },{
            "name":"Utiliser une variable et la modifier",
            "consts":{
