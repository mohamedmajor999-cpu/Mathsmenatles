                ]
            },
            "question":"Que va dire le lutin ?",
            "answer":"Le lutin va dire <span class='red'>${:varoupas==0?:var::a+:r*:b}</span>.",
            "value":"${:varoupas==0?:var::a+:r*:b}"
        }
