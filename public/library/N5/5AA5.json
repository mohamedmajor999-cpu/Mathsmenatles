                ],
                "operations":[
                    "+","-","*"
                ],
                "valeurs":[
                    "${:a+:b}", "${:a-:b}", "${:a*:b}"
                ]
            },
            "vars":{"a":"1_10", "b":"1_10", "ope0":"0_2", "var0":"0_9", "var":"${:varnames[:var0]}", "varoupas":"0_1"},
            "figure": {
                "type":"scratch",
                "content":[
                    "Quand @greenFlag est cliqué",
                    "mettre [${:var} v] à (${:a})",
                    "mettre [${:var} v] à ((${:var}) ${:operations[:ope0]} (${:b}))",
