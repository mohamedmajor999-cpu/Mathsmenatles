                ]
            },
            "question":"Que va dire le lutin ?",
            "answer":"Le lutin va dire <span class='red'>${:varoupas==0?:var::a+:b}</span>.",
            "value":"${:varoupas==0?:var::a+:b}"
        },{
            "name":"Utiliser une variable et la modifier",
