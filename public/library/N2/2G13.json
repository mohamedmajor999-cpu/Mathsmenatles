    "question": "Si $$\\vec{${:vecteurs[:v]}}(${:x[0]};${:x[1]})$$, alors $$${:k==0?:k+'\\times '::k}\\vec{${:vecteurs[:v]}} (?;?)$$",
    "answer":"$$\\vec{${:vecteurs[:v]}}(${:x[0]};${:x[1]})$$, donc $$${:k}\\vec{${:vecteurs[:v]}} \\color{red}{(${:k*:x[0]};${:k*:x[1]})}$$",
    "value":"\\left(${:k*:x[0]};${:k*:x[1]}\\right)"
