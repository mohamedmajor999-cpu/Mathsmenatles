{
    "title": "Supprimer les zéros inutiles d'un nombre",
    "description": "Réécrire un nombre en supprimant les zéros qui ne servent pas à sa lecture.",
    "ID":"8NC2",
    "dest": ["8NC","7NC","6NC","5NA"],
    "type":"text",
    "options":[{
        "name":"Petits nombres entiers < 10 000",
        "vars":{
            "z":"0_1_4",
            "cf":"1_9_4",
            "nb":"${'&nbsp;'+String(:z[0]*:cf[0])+' '+String(:z[1]*:cf[1])+String(:z[2]*:cf[2])+String(:z[3]*:cf[3])}",
            "ans":"${Number(''+(:z[0]*:cf[0])+(:z[1]*:cf[1])+(:z[2]*:cf[2])+(:z[3]*:cf[3]))}"
        }
    },{
        "name":"Nombres entiers < 1 000 000",
        "vars":{
            "z":"0_1_6",
            "cf":"1_9_6",
            "nb":"${String(:z[0]*:cf[0])+String(:z[1]*:cf[1])+String(:z[2]*:cf[2])+' '+String(:z[3]*:cf[3])+String(:z[4]*:cf[4])+String(:z[5]*:cf[5])}",
            "ans":"${Number(''+(:z[0]*:cf[0])+(:z[1]*:cf[1])+(:z[2]*:cf[2])+(:z[3]*:cf[3])+(:z[4]*:cf[4])+(:z[5]*:cf[5]))}"
        }
    },{
        "name":"Petits décimaux",
        "vars":{
            "z":"0_1_6",
            "cf":"1_9_6",
            "nb":"${String(:z[0]*:cf[0])+String(:z[1]*:cf[1])+String(:z[2]*:cf[2])+','+String(:z[3]*:cf[3])+String(:z[4]*:cf[4])+String(:z[5]*:cf[5])}",
            "ans":"${Number(''+(:z[0]*:cf[0])+(:z[1]*:cf[1])+(:z[2]*:cf[2])+'.'+(:z[3]*:cf[3])+(:z[4]*:cf[4])+(:z[5]*:cf[5]))}"
        }

    }],
    "question":"Recopier le nombre ${:nb} en supprimant les zéros inutiles",
    "answer":"${:nb}$$ = \\color{red}{${:ans}}$$",
    "value":"${:ans}"
}