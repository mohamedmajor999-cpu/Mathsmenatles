{
    "ID":"8NC4",
    "title":"Soustraire un nombre inférieur à 10 d'unités, dizaines, ... sans passage de dizaine",
    "description":"centaires, milliers, dixièmes, centièmes ou millièmes sans retenue",
    "dest":["8NC","7NC","6NC"],
    "type":"text",
    "options":[{
        "name":"Soustraire des miliers (CM2)",
        "vars":{
            "unites":"0_9",
            "dizaines":"0_9",
            "centaines":"0_9",
            "milliers":"1_9",
            "n":"${:milliers*1000+:centaines*100+:dizaines*10+:unites}",
            "x":"1_${:milliers}"
        },
        "question":[
            "$$${:n} - ${:x*1000}$$",
            "$$${:n} - ${:x}\\times 1000$$",
            "Combien font $$${:n}$$ moins $$${:x}$$ millier${:x>1?'s':''} ?"
        ],
        "answer":[
            "$$${:n} - ${:x*1000} = \\color{red}{${:n-:x*1000}}$$",
            "$$${:n} - ${:x}\\times 1000 = \\color{red}{${:n-:x*1000}}$$",
            "$$${:n}$$ moins $$${:x}$$ millier${:x>1?'s':''} font $$\\color{red}{${:n-:x*1000}}$$"
        ],
        "value":"${MMmath.round(:n-:x*1000)}"
    },{
