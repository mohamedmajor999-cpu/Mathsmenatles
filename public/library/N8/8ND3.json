    "shortq":["$$${:n}\\times ${:m}$$","$$${:n}\\times ${:m}$$","$$${:n}\\times ${:m}$$"],
    "answer":[
        "$$${:n}\\times ${:m}=${:ci}=\\color{red}{${:r}}$$",
        "$$${:n}\\times ${:m}=${:ci}=\\color{red}{${:r}}$$",
