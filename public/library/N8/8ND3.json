                "r":"${4*:n}"
            }
        },{
            "name":"Multiplier par 4 des multiples de 10",
            "vars":{
                "nom":"quadruple",
                "m":4,
                "n0":"1_9",
                "n":"${:n0*10}",
                "ci":"${:n*2}\\times 2",
                "r":"${4*:n}"
            }
        },{
            "name":"Multiplier par 4 un nombre entre 10 et 100",
            "vars":{
                "nom":"quadruple",
                "m":4,
                "u":"1_9",
                "d":"1_9",
                "n":"${:d*10+:u}",
                "ci":"${:n*2}\\times 2",
                "r":"${4*:n}"
            }
        },{
            "name":"Multiplier par 8 des nombres inférieurs à 10",
            "vars":{
