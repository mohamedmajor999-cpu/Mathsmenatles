            "vars":{
                "nom":"produit par 8",
                "m":8,
                "n0":"1_9",
                "n":"${:n0*10}",
                "ci":"${:n*2}\\times 4=${:n*4}\\times 2",
                "r":"${8*:n}"
            }
        },{
            "name":"Multiplier par 8 un nombre entre 10 et 100",
            "vars":{
                "nom":"produit par 8",
                "m":8,
                "u":"1_9",
                "d":"1_9",
                "n":"${:d*10+:u}",
                "ci":"${:n*2}\\times 4=${:n*4}\\times 2",
                "r":"${8*:n}"
            }
        }
