{
    "title":"CM Connaissances -> Soustraire un nombre entier inférieur à 10 d'unités, dizaines, ... à un nombre décimal lorsqu'il n'y a pas de retenues",
    "auteur":"Xavier Levet",
    "dest":["8NC","7NC"],
    "type":"text",
    "options":[{
        "name":"soustraire des centaines",
        "vars":{
            "unites":"1_9",
            "dizaines":"0_9",
            "centaines":"1_9",
            "dixiemes":"0_9",
            "centiemes":"0_9",
            "n":"${MMmath.round(:centaines*100+:dizaines*10+:unites+:dixiemes/10+:centiemes/100,2)}",
            "x":"1_${:centaines-1}"
        },
        "question":[
            "$$${:n} - ${MMmath.round(:x*100,2)}$$",
            "$$${:n} - ${:x}\\times 100$$",
            "Combien font $$${:n}$$ moins $$${:x}$$ centaine${:x>1?'s':''} ?"
        ],
        "answer":[
            "$$${:n} - ${MMmath.round(:x*100,2)} = \\color{red}{${MMmath.round(:n-:x*100,2)}}$$",
            "$$${:n} - ${:x}\\times 100 = \\color{red}{${MMmath.round(:n-:x*100,2)}}$$",
            "$$${:n}$$ moins $$${:x}$$ centaine${:x>1?'s':''} font $$\\color{red}{${MMmath.round(:n-:x*100,2)}}$$"
        ],
        "value":"${MMmath.round(:n-(:x*100))}"
    },{
