                    ["point", [9, 1], {"name":"B","face":"", "label":{"visible":false}}],
                    ["point", [9, 4], {"name":"C","face":"", "label":{"visible":false}}],
                    ["point", [1, 4], {"name":"D","face":"", "label":{"visible":false}}],
                    ["polygon", ["A","B","C","D"], {"fillColor":"none"}],
                    ["fillSquares",[], {"width":"${'2,4,6'.indexOf(:den)>-1?2:'8,12'.indexOf(:den)>-1?4:1}","height":"${:den==2?1:'3,6,12'.indexOf(:den)>-1?3:2}","qty":":num","left":1,"top":1,"scaleX":"${'2,4,6'.indexOf(:den)>-1?4:'8,12'.indexOf(:den)>-1?2:8}","scaleY":"${:den==2?3:'3,6,12'.indexOf(:den)>-1?1:1.5}","allLines":true}]
