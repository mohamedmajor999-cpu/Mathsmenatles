                    ["point", [1, 2], {"name":"D","face":"", "label":{"visible":false}}],
                    ["polygon", ["A","B","C","D"], {"fillColor":"none"}],
                    ["fillSquares",[], {"width":"${:den}","height":"1","qty":":num","left":1,"top":1,"scaleX":"${MMmath.round(12/:den,4)}","scaleY":1,"allLines":true}]
