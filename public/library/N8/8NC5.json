            "x":"1_${9-:centaines}"
        },
        "question":[
            "$$${:n} + ${:x*100}$$",
            "$$${:n} + ${:x}\\times 100$$",
            "Combien font $$${:n}$$ et $$${:x}$$ centaine${:x>1?'s':''} ?"
        ],
        "answer":[
            "$$${:n} + ${:x*100} = \\color{red}{${:n+:x*100}}$$",
            "$$${:n} + ${:x}\\times 100 = \\color{red}{${:n+:x*100}}$$",
            "$$${:n}$$ et $$${:x}$$ centaine${:x>1?'s':''} font $$\\color{red}{${:n+:x*100}}$$"
        ],
        "value":"${MMmath.round(:n+:x*100)}"
    },{
