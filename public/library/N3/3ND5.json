{
    "title":"Résoudre une équation se ramenant à x² = a",
    "description":"Donner les solutions d'une équation x² = a ou ax²=b",
    "type":"latex",
    "textSize":"medium",
    "ID":"3ND5",
    "dest":["3ND", "2N3","2N3"],
    "keys":["{","-",";","√","Ø","_","_","_"],
    "consts":{"lettres":["u","v","t","x", "y","z"]},
    "options":[{
        "name":"x² = a, a entier",
        "vars":{"n":"1_20","alea":"1_10", "a":"${:alea<10?:n*:n:-:n*:n}" , "l":"0_5","x":"${:lettres[:l]}"},
        "question": "\\text{Résoudre } ${:x}^2=${:a}",
        "answer":"${:x}^2=${:a} \\text{ pour } \\color{red}{${:a<0?'\\text{Pas de solution}':(:x+'\\in\\{-'+:n+';'+:n+'\\}')}}"
    },{
        "name":"x² = a, a décimal",
        "vars":{"n":"d0.1_2_1","alea":"1_10", "a":"${:alea<10?MMmath.round(:n*:n,2):-MMmath.round(:n*:n,2)}" , "l":"0_5","x":"${:lettres[:l]}"},
        "question": "\\text{Résoudre } ${:x}^2=${:a}",
        "answer":"${:x}^2=${:a} \\text{ pour } \\color{red}{${:a>0?(:x+'\\in\\{-'+:n+';'+:n+'\\}'):'\\text{Pas de solution}'}}"
    },{
        "name":"x² + a = 0, a entier",
        "vars":{"n":"1_20","alea":"1_10", "a":"${:alea>4?:n*:n:-:n*:n}" , "l":"0_5","x":"${:lettres[:l]}"},
        "question": "\\text{Résoudre } ${:x}^2${MMmath.signedNumber(-:a)}=0",
        "answer":"${:x}^2${MMmath.signedNumber(-:a)}=0 \\text{ pour } \\color{red}{${:a<0?'\\text{Pas de solution}':(:x+'\\in\\{-'+:n+';'+:n+'\\}')}}"
    },{
        "name":"x² + a = 0, a décimal",
        "vars":{"n":"d0.1_2_1","alea":"1_10", "a":"${:alea>4?MMmath.round(:n*:n,2):MMmath.round(-:n*:n,2)}" , "l":"0_5","x":"${:lettres[:l]}"},
        "question": "\\text{Résoudre } ${:x}^2${MMmath.signedNumber(-:a)}=0",
        "answer":"${:x}^2${MMmath.signedNumber(-:a)}=0 \\text{ pour } \\color{red}{${:a<0?'\\text{Pas de solution}':(:x+'\\in\\{-'+:n+';'+:n+'\\}')}}"
    },{
        "name":"ax² = b, a, b entiers",
        "vars":{"a":"-20_20_^0","alea":"1_10", "n":"-20_20_^0", "b":"${(:alea<3 || :a*:n>0)?:n:-:n}" , "l":"0_5","x":"${:lettres[:l]}"},
        "question": "\\text{Résoudre } ${MMmath.signIfOne(:a)}${:x}^2=${:b}",
        "answer":"${MMmath.signIfOne(:a)}${:x}^2=${:b} \\text{ pour } \\color{red}{${:a*:b<0?'\\text{Pas de solution}':(:x+'\\in\\{-'+MMmath.calc('\\sqrt{'+:b+'\\div('+:a+')}')+';'+MMmath.calc('\\sqrt{'+:b+'\\div('+:a+')}')+'\\}')}}",
        "value":"${:a*:b<0?'\\text{Pas de solution}':(:x+'\\in\\{-'+MMmath.calc('\\sqrt{'+:b+'\\div('+:a+')}')+';'+MMmath.calc('\\sqrt{'+:b+'\\div('+:a+')}')+'\\}')}"
    }],
    "value":["${:a<0?'\\empty':-:n+';'+:n}","${:a<0?'\\empty'::n+';-'+:n}","${:a<0?'\\empty':'\\left\\{'+-:n+';'+:n+'\\right\\}'}","${:a<0?'\\empty':'\\left\\{'+:n+';-'+:n+'\\right\\}'}"]
}