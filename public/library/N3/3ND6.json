{
    "title":"Résoudre une équation produit nul",
    "description":"Donner les solutions d'une équation présentée sous la forme d'un produit nul.",
    "type":"text",
    "textSize":"medium",
    "ID":"3ND6",
    "dest":["3ND","2N3"],
    "keys":["{","-",";","/","_","_","_","_"],
    "consts":{"lettres":["u","v","t","x", "y", "z"]},
    "options":[{
        "name":"Résoudre (x+a)(x+b)=0",
        "vars":{"a":"-10_10_2_^&","l":"0_5","x":"${:lettres[:l]}"},
        "question": "$$${:a[0]!=0?'('+:x+MMmath.signedNumber(:a[0])+')'::x}${:a[1]!=0?'('+:x+MMmath.signedNumber(:a[1])+')'::x}=0$$",
        "answer":":question <br>si $$${:x}=\\color{red}{${-:a[0]}}$$ ou $$${:x}=\\color{red}{${-:a[1]}}$$",
        "value":["${-:a[0]};${-:a[1]}","${-:a[1]};${-:a[0]}","\\left\\{${-:a[0]};${-:a[1]}\\right\\}","\\left\\{${-:a[0]};${-:a[1]}\\right\\}"]
    },{
        "name":"Résoudre (ax+b)(cx+d)=0",
        "vars":{"a":"-10_10_2_^0","b":"-10_10_2_^&","l":"0_5","x":"${:lettres[:l]}"},
        "question": "$$${:b[0]!=0?'('+MMmath.signIfOne(:a[0])+:x+MMmath.signedNumber(:b[0])+')':MMmath.signIfOne(:a[0])+:x}${:b[1]!=0?'('+MMmath.signIfOne(:a[1])+:x+MMmath.signedNumber(:b[1])+')':'\\times'+MMmath.signIfOne(:a[1])+:x}=0$$",
        "answer":":question <br>si $$${:x}=\\color{red}{${MMmath.fractionSimplifiee(-:b[0],:a[0])}}$$ ou $$${:x}=\\color{red}{${MMmath.fractionSimplifiee(-:b[1],:a[1])}}$$",
        "value":["${MMmath.fractionSimplifiee(-:b[0],:a[0])};${MMmath.fractionSimplifiee(-:b[1],:a[1])}",
            "\\left\\{${MMmath.fractionSimplifiee(-:b[0],:a[0])};${MMmath.fractionSimplifiee(-:b[1],:a[1])}\\right\\}",
            "${MMmath.fractionSimplifiee(-:b[1],:a[1])};${MMmath.fractionSimplifiee(-:b[0],:a[0])}",
            "\\left\\{${MMmath.fractionSimplifiee(-:b[1],:a[1])};${MMmath.fractionSimplifiee(-:b[0],:a[0])}\\right\\}"
        ]
    }
    ]
}