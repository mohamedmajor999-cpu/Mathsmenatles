            "milliers":"1_9",
            "n":"${:milliers*1000+:centaines*100+:dizaines*10+:unites}",
            "x":"${10-:milliers}_9"
        },
        "question":[
            "$$${:n} + ${:x*1000}$$",
            "$$${:n} + ${:x}\\times 1000$$",
            "Combien font $$${:n}$$ et $$${:x}$$ millier${:x>1?'s':''} ?"
        ],
        "answer":[
            "$$${:n} + ${:x*1000} = \\color{red}{${:n+:x*1000}}$$",
            "$$${:n} + ${:x}\\times 1000 = \\color{red}{${:n+:x*1000}}$$",
            "$$${:n}$$ et $$${:x}$$ centaine${:x>1?'s':''} font $$\\color{red}{${:n+:x*1000}}$$"
        ],
        "value":"${MMmath.round(:n+:x*1000)}"
